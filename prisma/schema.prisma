generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model usuarios {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre        String   @db.VarChar(120)
  correo        String   @unique @db.VarChar(160)
  password_hash String   @db.VarChar(255)
  rol           String   @default("admin") @db.VarChar(40)
  activo        Boolean  @default(true)
  created_at              DateTime                 @default(now()) @db.Timestamptz(6)
  updated_at              DateTime                 @default(now()) @updatedAt @db.Timestamptz(6)
  movimientos_inventario  inventario_movimientos[]
}

model empleados {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String   @db.VarChar(120)
  cargo      String?  @db.VarChar(80)
  telefono   String?  @db.VarChar(40)
  activo     Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  rutas      rutas[]
}

model rutas {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre      String     @db.VarChar(100)
  descripcion String?
  empleado_id String?    @db.Uuid
  activa      Boolean    @default(true)
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  dias_semana Int[]      @default([]) @db.SmallInt
  frecuencia  String     @default("semanal") @db.VarChar(20)
  clientes    clientes[]
  pedidos     pedidos[]
  empleado    empleados? @relation(fields: [empleado_id], references: [id], onUpdate: NoAction)
}

model clientes {
  id              String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String               @db.VarChar(160)
  telefono        String               @unique @db.VarChar(40)
  direccion       String?
  ruta_id         String?              @db.Uuid
  activo          Boolean              @default(true)
  notas           String?
  created_at      DateTime             @default(now()) @db.Timestamptz(6)
  updated_at      DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  codigo_mekano   String?              @unique @db.VarChar(40)
  ruta            rutas?               @relation(fields: [ruta_id], references: [id], onUpdate: NoAction)
  conversaciones  conversaciones_wpp[]
  pedidos         pedidos[]
  precios_cliente precios_cliente[]

  @@index([codigo_mekano], map: "idx_clientes_codigo_mek")
  @@index([ruta_id], map: "idx_clientes_ruta")
  @@index([telefono], map: "idx_clientes_telefono")
}

model categorias {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre     String      @db.VarChar(100)
  slug       String      @unique @db.VarChar(50)
  emoji      String?     @db.VarChar(10)
  orden      Int         @default(0)
  activa     Boolean     @default(true)
  created_at DateTime    @default(now()) @db.Timestamptz(6)
  updated_at DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  productos  productos[]

  @@index([slug], map: "idx_categorias_slug")
}

model productos {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre          String          @db.VarChar(140)
  descripcion     String?
  imagen_url      String?
  unidad          String          @default("unidad") @db.VarChar(30)
  precio_base     Decimal         @default(0) @db.Decimal(12, 2)
  activo          Boolean         @default(true)
  orden           Int             @default(0)
  categoria_id    String?         @db.Uuid
  created_at      DateTime        @default(now()) @db.Timestamptz(6)
  updated_at      DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  categoria       categorias?     @relation(fields: [categoria_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  inventario      inventario?
  inventario_item inventario_items?
  pedido_items    pedido_items[]
  precios_cliente precios_cliente[]

  @@index([categoria_id], map: "idx_productos_categoria")
}

model precios_cliente {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id  String    @db.Uuid
  producto_id String    @db.Uuid
  precio      Decimal   @db.Decimal(12, 2)
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  updated_at  DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  cliente     clientes  @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  producto    productos @relation(fields: [producto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([cliente_id, producto_id])
  @@index([cliente_id], map: "idx_precios_cliente_cli")
  @@index([producto_id], map: "idx_precios_cliente_prod")
}

model pedidos {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id     String               @db.Uuid
  ruta_id        String?              @db.Uuid
  estado         String               @default("pendiente") @db.VarChar(30)
  total          Decimal              @default(0) @db.Decimal(12, 2)
  fecha_pedido   DateTime             @default(dbgenerated("CURRENT_DATE")) @db.Date
  confirmado_at  DateTime?            @db.Timestamptz(6)
  notas          String?
  created_at     DateTime             @default(now()) @db.Timestamptz(6)
  updated_at     DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  conversaciones conversaciones_wpp[]
  items          pedido_items[]
  cliente        clientes             @relation(fields: [cliente_id], references: [id], onUpdate: NoAction)
  ruta           rutas?               @relation(fields: [ruta_id], references: [id], onUpdate: NoAction)

  @@index([cliente_id], map: "idx_pedidos_cliente")
  @@index([estado], map: "idx_pedidos_estado")
  @@index([fecha_pedido], map: "idx_pedidos_fecha")
}

model pedido_items {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pedido_id       String    @db.Uuid
  producto_id     String    @db.Uuid
  producto_nombre String    @db.VarChar(140)
  cantidad        Decimal   @db.Decimal(12, 2)
  precio_unitario Decimal   @db.Decimal(12, 2)
  subtotal        Decimal   @db.Decimal(12, 2)
  created_at      DateTime  @default(now()) @db.Timestamptz(6)
  pedido          pedidos   @relation(fields: [pedido_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  producto        productos @relation(fields: [producto_id], references: [id], onUpdate: NoAction)

  @@index([pedido_id], map: "idx_pedido_items_pedido")
}

model inventario {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  producto_id  String    @unique @db.Uuid
  stock_actual Decimal   @default(0) @db.Decimal(12, 2)
  stock_minimo Decimal   @default(0) @db.Decimal(12, 2)
  updated_at   DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  producto     productos @relation(fields: [producto_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model conversaciones_wpp {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cliente_id        String?   @db.Uuid
  telefono          String    @db.VarChar(40)
  estado_flujo      String    @default("inicio") @db.VarChar(50)
  carrito           Json?     @default("[]")
  pedido_id         String?   @db.Uuid
  ultimo_mensaje_at DateTime  @default(now()) @db.Timestamptz(6)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  cliente           clientes? @relation(fields: [cliente_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pedido            pedidos?  @relation(fields: [pedido_id], references: [id], onUpdate: NoAction)

  @@index([telefono], map: "idx_conv_telefono")
}

model configuracion {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nombre_negocio        String   @default("Productos Jalil") @db.VarChar(160)
  nit                   String?  @db.VarChar(40)
  direccion             String?
  telefono              String?  @db.VarChar(40)
  hora_recordatorio     DateTime @default(dbgenerated("'07:00:00'::time without time zone")) @db.Time(6)
  horas_espera_followup Int      @default(3) @db.SmallInt
  mensaje_recordatorio  String   @default("¡Hola! 👋 Es momento de hacer tu pedido para mañana. ¿Deseas realizar tu pedido hoy?")
  mensaje_followup      String   @default("🔔 Recordatorio: aún no hemos recibido tu pedido. ¿Deseas realizarlo ahora?")
  updated_at            DateTime @default(now()) @db.Timestamptz(6)
}

model inventario_items {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  nombre                 String    @db.VarChar(160)

  /// "insumo" | "materia_prima" | "producto_terminado"
  tipo                   String    @db.VarChar(30)

  unidad                 String    @default("kg") @db.VarChar(30)
  stock_actual           Decimal   @default(0) @db.Decimal(12, 2)
  stock_minimo           Decimal   @default(0) @db.Decimal(12, 2)
  costo_unitario         Decimal   @default(0) @db.Decimal(12, 2)

  // Solo insumos
  proveedor              String?   @db.VarChar(120)

  // Solo materias primas
  tipo_animal            String?   @db.VarChar(60)
  requiere_refrigeracion Boolean   @default(false)

  // Materias primas + producto terminado
  fecha_vencimiento      DateTime? @db.Date

  // Solo producto terminado — vínculo opcional con catálogo
  producto_id            String?   @unique @db.Uuid

  activo                 Boolean   @default(true)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  producto               productos?              @relation(fields: [producto_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
  movimientos            inventario_movimientos[]

  @@index([tipo],       map: "idx_inv_items_tipo")
  @@index([activo],     map: "idx_inv_items_activo")
  @@index([producto_id],map: "idx_inv_items_prod")
}

model inventario_movimientos {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  item_id           String   @db.Uuid

  /// "entrada" | "salida" | "ajuste"
  tipo              String   @db.VarChar(20)

  /// "compra" | "venta" | "merma" | "produccion" | "ajuste_manual"
  motivo            String   @default("ajuste_manual") @db.VarChar(30)

  cantidad          Decimal  @db.Decimal(12, 2)
  cantidad_anterior Decimal  @db.Decimal(12, 2)
  cantidad_nueva    Decimal  @db.Decimal(12, 2)
  notas             String?
  usuario_id        String?  @db.Uuid
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  item              inventario_items @relation(fields: [item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  usuario           usuarios?        @relation(fields: [usuario_id], references: [id], onDelete: SetNull, onUpdate: NoAction)

  @@index([item_id],    map: "idx_inv_mov_item")
  @@index([tipo],       map: "idx_inv_mov_tipo")
  @@index([created_at], map: "idx_inv_mov_fecha")
  @@index([usuario_id], map: "idx_inv_mov_usuario")
}
